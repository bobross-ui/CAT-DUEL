generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QuestionCategory {
  QUANT
  DILR
  VARC
}

enum QuestionSource {
  MANUAL
  AI
}

enum RankTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

model User {
  id                    String    @id @default(uuid())
  firebaseUid           String    @unique @map("firebase_uid")
  email                 String    @unique
  displayName           String?   @unique @map("display_name")
  avatarUrl             String?   @map("avatar_url")
  role                  String    @default("user")
  eloRating             Int       @default(1200) @map("elo_rating")
  rankTier              RankTier  @default(SILVER) @map("rank_tier")
  gamesPlayed           Int       @default(0) @map("games_played")
  wins                  Int       @default(0)
  draws                 Int       @default(0)
  winRate               Float     @default(0) @map("win_rate")
  currentStreak         Int       @default(0) @map("current_streak")
  longestStreak         Int       @default(0) @map("longest_streak")
  lastActiveDate        DateTime? @map("last_active_date") @db.Date
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  practiceAnswers PracticeAnswer[]
  matchesAsPlayer1 Match[]        @relation("MatchPlayer1")
  matchesAsPlayer2 Match[]        @relation("MatchPlayer2")
  matchAnswers    MatchAnswer[]

  @@index([eloRating(sort: Desc)])
  @@index([rankTier, eloRating(sort: Desc)])
  @@map("users")
}

model Question {
  id            String           @id @default(uuid())
  category      QuestionCategory
  subTopic      String?          @map("sub_topic")
  difficulty    Int              @default(3)
  text          String
  options       Json
  correctAnswer Int              @map("correct_answer")
  explanation   String
  source        QuestionSource   @default(MANUAL)
  isVerified    Boolean          @default(false) @map("is_verified")
  timesServed   Int              @default(0) @map("times_served")
  timesCorrect  Int              @default(0) @map("times_correct")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  practiceAnswers PracticeAnswer[]
  matchAnswers    MatchAnswer[]

  @@index([category, difficulty])
  @@index([isVerified, category])
  @@map("questions")
}

model PracticeAnswer {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  questionId     String   @map("question_id")
  selectedAnswer Int      @map("selected_answer")
  isCorrect      Boolean  @map("is_correct")
  timeTakenMs    Int      @map("time_taken_ms")
  createdAt      DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@index([userId, questionId])
  @@map("practice_answers")
}

model Match {
  id              String   @id
  player1Id       String   @map("player1_id")
  player2Id       String   @map("player2_id")
  winnerId        String?  @map("winner_id")
  isDraw          Boolean  @map("is_draw")
  player1Score      Int      @map("player1_score")
  player2Score      Int      @map("player2_score")
  player1EloChange  Int      @default(0) @map("player1_elo_change")
  player2EloChange  Int      @default(0) @map("player2_elo_change")
  player1Answered   Int      @map("player1_answered")
  player2Answered   Int      @map("player2_answered")
  totalQuestions    Int      @map("total_questions")
  durationSeconds   Int      @map("duration_seconds")
  status            String   @default("completed")
  finishedAt        DateTime @map("finished_at")
  createdAt         DateTime @default(now()) @map("created_at")

  player1 User         @relation("MatchPlayer1", fields: [player1Id], references: [id])
  player2 User         @relation("MatchPlayer2", fields: [player2Id], references: [id])
  answers MatchAnswer[]

  @@index([player1Id, finishedAt(sort: Desc)])
  @@index([player2Id, finishedAt(sort: Desc)])
  @@map("matches")
}

model MatchAnswer {
  id             String  @id @default(uuid())
  matchId        String  @map("match_id")
  userId         String  @map("user_id")
  questionId     String  @map("question_id")
  selectedAnswer Int     @map("selected_answer")
  isCorrect      Boolean @map("is_correct")
  timeTakenMs    Int     @map("time_taken_ms")

  match    Match    @relation(fields: [matchId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@index([matchId, userId])
  @@map("match_answers")
}
